# Saber-Translator 翻译脚本配置
# 复制此文件为 .env 并填入你的 API Key

# Gemini API Key (必填)
GEMINI_API_KEY=your_gemini_api_key_here

# 翻译模型 (可选, 默认 gemini-3.1-pro-preview)
TRANSLATE_MODEL=gemini-3.1-pro-preview

# 字体路径 (可选, 默认站酷快乐体)
TRANSLATE_FONT=src/app/static/fonts/ZhanKuKuaiLeTi.ttf

# 目标语言 / 源语言 (可选)
TRANSLATE_TARGET_LANG=Chinese
TRANSLATE_SOURCE_LANG=japanese

# 后端 API 地址 (可选, 默认 http://127.0.0.1:5000/api)
TRANSLATE_API_BASE=http://127.0.0.1:5000/api
